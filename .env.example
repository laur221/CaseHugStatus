# Environment Variables pentru CasehugBot Docker

# Timezone pentru logs și scheduling
TZ=Europe/Bucharest

# Python buffering (recomandabil pentru logs în Docker)
PYTHONUNBUFFERED=1

# Log level (opțional)
# LOG_LEVEL=DEBUG

# Chrome/Chromium binary (setat automat în Docker)
# CHROME_BIN=/usr/bin/chromium

# ChromeDriver binary (setat automat în Docker)
# CHROMEDRIVER_BIN=/usr/bin/chromedriver
