# Database Configuration
# SQLAlchemy URL (the app selects an available PostgreSQL driver automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/casehugauto

# Bot Configuration
HEADLESS_MODE=true
CHECK_INTERVAL_HOURS=6
AUTO_RUN_ON_STARTUP=false

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# FlareSolverr (for Docker Cloudflare bypass)
FLARESOLVERR_URL=http://127.0.0.1:8191
USE_FLARESOLVERR=false

# Application
DEBUG=false
APP_VERSION=1.0.0
